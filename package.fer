let cxx = import('std/cxx');
let vec = import('std/vec');
let package = import('std/package');

let pkg = package.new(
    name = 'SSH',
    desc = 'SSH connection and scripting using Feral.',
    version = '0.1.0',
    feral = '>=2.1.1',
    author = vec.new('Chirag-Khandelwal <github@mail.chiragkh.me>')
);

let ssh = cxx.findLibrary('libssh', version = '>=0.12.0').ok();

let ext = cxx.newExt('SSH');
ext.requires(ssh);
ext.addSources('lib/SSH.cpp'.path());

pkg.addTarget(ext);